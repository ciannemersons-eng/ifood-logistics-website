# Public site URL (used for canonical links, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=https://www.ifoodlogistics.com

# Sanity CMS — used by the Next.js app (browser + server)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=

# Sanity CMS — used by the standalone Sanity Studio dev/deploy CLI
# (`npm run sanity:dev` / `npm run sanity:deploy`). Sanity's own tooling only
# inlines SANITY_STUDIO_-prefixed variables into the Studio, not NEXT_PUBLIC_
# ones, so these must be set separately (same values as above).
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# Supabase (server-only, never expose to the browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (server-only)
RESEND_API_KEY=
INQUIRY_NOTIFICATION_EMAIL=
INQUIRY_FROM_EMAIL=

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
